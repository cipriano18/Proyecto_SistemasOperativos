<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyect.clientereservas.controller.RegisterController"
      styleClass="root-pane"
      prefWidth="920" prefHeight="600">

    <!-- PANEL IZQUIERDO -->
    <VBox styleClass="hero-panel" prefWidth="320" prefHeight="600" spacing="0">
        <padding><Insets top="40" left="36" right="36" bottom="40"/></padding>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox styleClass="logo-box" minWidth="38" minHeight="38" alignment="CENTER">
                <Label text="A" style="-fx-font-size:18px; -fx-font-weight:700; -fx-text-fill:white;"/>
            </VBox>
            <Label text="Auditorio UNA" styleClass="logo-text"/>
        </HBox>
        <Region VBox.vgrow="ALWAYS"/>
        <VBox spacing="14">
            <Label text="NUEVA CUENTA" styleClass="hero-badge"/>
            <Label text="Registro de cliente"
                   style="-fx-font-size:28px; -fx-font-weight:700; -fx-text-fill:white; -fx-wrap-text:true;"
                   prefWidth="248"/>
            <Label text="Cree su cuenta para acceder al sistema de reservas del auditorio."
                   styleClass="hero-subtitle" prefWidth="248" wrapText="true"/>
        </VBox>
        <Region minHeight="40"/>
        <Label text="© 2025 Universidad Nacional"
               style="-fx-font-size:10px; -fx-text-fill:#537090;"/>
    </VBox>

    <!-- PANEL DERECHO -->
    <VBox styleClass="form-panel" HBox.hgrow="ALWAYS" alignment="CENTER">
        <padding><Insets top="60" left="60" right="60" bottom="40"/></padding>
        <VBox spacing="0" maxWidth="340">

            <VBox spacing="6">
                <Label text="Crear cuenta" styleClass="form-title"/>
                <Label text="Ingrese sus datos para registrarse." styleClass="form-subtitle"/>
            </VBox>

            <Region minHeight="32"/>

            <VBox spacing="6">
                <Label text="USUARIO *" styleClass="field-label"/>
                <TextField fx:id="usernameField" styleClass="text-field"
                           promptText="nombre.usuario" prefWidth="340"/>
            </VBox>

            <Region minHeight="16"/>

            <VBox spacing="6">
                <Label text="CONTRASEÑA *" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" styleClass="password-field"
                               promptText="Mín. 8 chars, 1 mayús, 1 núm" prefWidth="340"/>
            </VBox>

            <Region minHeight="16"/>

            <VBox spacing="6">
                <Label text="CONFIRMAR CONTRASEÑA *" styleClass="field-label"/>
                <PasswordField fx:id="confirmPasswordField" styleClass="password-field"
                               promptText="Repita la contraseña" prefWidth="340"/>
            </VBox>

            <Region minHeight="8"/>

            <Label fx:id="messageLabel" text="" wrapText="true" prefWidth="340"/>

            <Region minHeight="24"/>

            <Button fx:id="registerButton" text="Crear cuenta"
                    styleClass="btn-primary" prefWidth="340"
                    onAction="#handleRegister"/>

            <Region minHeight="16"/>

            <Button text="Volver al login" styleClass="btn-secondary"
                    prefWidth="340" onAction="#handleBack"/>

        </VBox>
    </VBox>
</HBox>