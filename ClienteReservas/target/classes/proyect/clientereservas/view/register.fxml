<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="proyect.clientereservas.controller.RegisterController"
      styleClass="root-pane"
      prefWidth="920" prefHeight="600">

    <!-- PANEL IZQUIERDO -->
    <VBox styleClass="hero-panel" prefWidth="320" prefHeight="600" spacing="0">
        <padding><Insets top="40" left="36" right="36" bottom="40"/></padding>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox styleClass="logo-box" minWidth="38" minHeight="38" alignment="CENTER">
                <Label text="A" style="-fx-font-size:18px; -fx-font-weight:700; -fx-text-fill:white;"/>
            </VBox>
            <Label text="Auditorio UNA" styleClass="logo-text"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox spacing="14">
            <Label text="NUEVO ADMINISTRADOR" styleClass="hero-badge"/>
            <Label text="Registro de cuenta" style="-fx-font-size:28px; -fx-font-weight:700; -fx-text-fill:white; -fx-wrap-text:true;" prefWidth="248"/>
            <Label text="Complete los datos para crear una cuenta de administrador del sistema."
                   styleClass="hero-subtitle" prefWidth="248" wrapText="true"/>
        </VBox>

        <Region minHeight="40"/>
        <Label text="© 2025 Universidad Nacional" style="-fx-font-size:10px; -fx-text-fill:#537090;"/>
    </VBox>

    <!-- PANEL DERECHO CON SCROLL -->
    <VBox styleClass="form-panel" HBox.hgrow="ALWAYS">
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" VBox.vgrow="ALWAYS">
            <VBox spacing="0" style="-fx-padding: 40px 60px; -fx-background-color: white;">

                <!-- Header -->
                <VBox spacing="4">
                    <Label text="Datos de la cuenta" styleClass="form-title"/>
                    <Label text="Todos los campos marcados son obligatorios." styleClass="form-subtitle"/>
                </VBox>

                <Region minHeight="24"/>

                <!-- ── SECCIÓN CREDENCIALES ── -->
                <Label text="CREDENCIALES DE ACCESO" styleClass="section-header"/>
                <Region minHeight="12"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="USUARIO *" styleClass="field-label"/>
                        <TextField fx:id="usernameField" styleClass="text-field" promptText="nombre.usuario"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="CONTRASEÑA *" styleClass="field-label"/>
                        <PasswordField fx:id="passwordField" styleClass="password-field" promptText="Min. 8 chars, 1 mayús, 1 núm"/>
                    </VBox>
                </HBox>

                <Region minHeight="24"/>
                <Region styleClass="divider-line" prefHeight="1"/>
                <Region minHeight="20"/>

                <!-- ── SECCIÓN DATOS PERSONALES ── -->
                <Label text="DATOS PERSONALES" styleClass="section-header"/>
                <Region minHeight="12"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="PRIMER NOMBRE *" styleClass="field-label"/>
                        <TextField fx:id="fNameField" styleClass="text-field" promptText="Ej: Juan"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="SEGUNDO NOMBRE" styleClass="field-label"/>
                        <TextField fx:id="mNameField" styleClass="text-field" promptText="Opcional"/>
                    </VBox>
                </HBox>

                <Region minHeight="14"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="PRIMER APELLIDO *" styleClass="field-label"/>
                        <TextField fx:id="fSurnameField" styleClass="text-field" promptText="Ej: Pérez"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="SEGUNDO APELLIDO *" styleClass="field-label"/>
                        <TextField fx:id="mSurnameField" styleClass="text-field" promptText="Ej: Rodríguez"/>
                    </VBox>
                </HBox>

                <Region minHeight="14"/>

                <VBox spacing="6">
                    <Label text="CÉDULA DE IDENTIDAD *" styleClass="field-label"/>
                    <TextField fx:id="identityCardField" styleClass="text-field"
                               promptText="Ej: 1-1234-5678" prefWidth="200" maxWidth="220"/>
                </VBox>

                <Region minHeight="24"/>
                <Region styleClass="divider-line" prefHeight="1"/>
                <Region minHeight="20"/>

                <!-- ── SECCIÓN CONTACTO ── -->
                <Label text="INFORMACIÓN DE CONTACTO" styleClass="section-header"/>
                <Region minHeight="12"/>

                <HBox spacing="16">
                    <VBox spacing="6" prefWidth="160">
                        <Label text="TIPO *" styleClass="field-label"/>
                        <ComboBox fx:id="contactTypeCombo" styleClass="text-field"
                                  promptText="Tipo" prefWidth="160"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="VALOR *" styleClass="field-label"/>
                        <TextField fx:id="contactValueField" styleClass="text-field"
                                   promptText="Ej: correo@una.cr o 8888-8888"/>
                    </VBox>
                </HBox>

                <Region minHeight="20"/>

                <!-- Mensaje -->
                <Label fx:id="messageLabel" text="" wrapText="true" styleClass="msg-error"/>

                <Region minHeight="24"/>

                <!-- Botones -->
                <HBox spacing="12">
                    <Button text="Volver al login" styleClass="btn-secondary"
                            prefWidth="160" onAction="#handleBack"/>
                    <Button fx:id="registerButton" text="Crear administrador"
                            styleClass="btn-primary" HBox.hgrow="ALWAYS"
                            onAction="#handleRegister"/>
                </HBox>

                <Region minHeight="40"/>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
